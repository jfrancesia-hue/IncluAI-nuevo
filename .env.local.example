# ============================================
# IncluIA — Variables de entorno
# Copiar a .env.local y completar con valores reales
# ============================================

# Supabase (obtener en supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres (Supabase → Project Settings → Database → Connection string → "Transaction pooler")
DATABASE_URL=

# Anthropic Claude API (console.anthropic.com)
ANTHROPIC_API_KEY=

# Mercado Pago Argentina (mercadopago.com.ar/developers)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Resend (resend.com → API Keys)
RESEND_API_KEY=
RESEND_FROM_EMAIL=IncluIA <noreply@inclua.com.ar>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# v2.1 — Multimedia (agente estructurado)
# ============================================

# Unsplash API — enriquece imágenes en guías v2.1
# Registrarse en: https://unsplash.com/developers (gratis, 50 req/hora, 5000/mes)
UNSPLASH_ACCESS_KEY=

# YouTube Data API — opcional, para verificar embedIds en el futuro
# Consola: https://console.cloud.google.com/ → API & Services → YouTube Data API v3
YOUTUBE_API_KEY=
