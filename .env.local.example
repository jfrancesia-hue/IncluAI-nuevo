# ============================================
# IncluIA — Variables de entorno
# Copiar a .env.local y completar con valores reales.
# ============================================

# --- Supabase (obligatorio) ---
# Obtener en supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres (Supabase → Project Settings → Database → Connection string → "Transaction pooler")
DATABASE_URL=

# --- Anthropic Claude API (obligatorio para generar guías) ---
# console.anthropic.com
ANTHROPIC_API_KEY=

# --- Mercado Pago Argentina (obligatorio para monetización) ---
# mercadopago.com.ar/developers
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# --- Resend (emails transaccionales) ---
# resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=IncluIA <noreply@incluia.com.ar>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# v2.1 — Multimedia (agente estructurado)
# ============================================

# Unsplash API — enriquece imágenes en guías v2.1
# Registrarse en: https://unsplash.com/developers (gratis, 50 req/hora en demo)
# Nota: Unsplash requiere aprobación manual de cada nueva app (5-10 días hábiles)
UNSPLASH_ACCESS_KEY=

# Pexels API — alternativa a Unsplash, aprobación instantánea
# Obtener en: https://www.pexels.com/api/ → dashboard (gratis, 200 req/hora, 20k/mes)
PEXELS_API_KEY=

# YouTube Data API — opcional, para verificar embedIds en el futuro
YOUTUBE_API_KEY=

# --- Upstash Redis (rate limiting, opcional pero recomendado en prod) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# FASE 8 / Gobierno / Inversores — opcionales
# Todo lo que sigue es opcional. El sistema funciona degradado sin esto.
# ============================================

# --- Sentry (observabilidad) ---
# Sin SENTRY_DSN, los errores se loguean solo a console.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- PostHog (feature flags + product analytics) ---
# Sin esto, los flags caen a variables NEXT_PUBLIC_FLAG_*
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Flags manuales (fallback si no hay PostHog)
NEXT_PUBLIC_FLAG_NUEVO_ONBOARDING_FAMILIAS=false
NEXT_PUBLIC_FLAG_GUIA_RENDERER_V2=true
NEXT_PUBLIC_FLAG_GOV_HEATMAP_EXPERIMENTAL=false

# --- Gobierno Fase 8 ---
# Sal secreta para el hash de CUEs devueltos al panel provincial.
# Rotarla invalida el masking histórico (fuerza regenerar dashboards).
GOV_CUE_MASK_SALT=

# --- Ciudadano Digital Córdoba (SSO gubernamental) ---
CIDI_CLIENT_ID=
CIDI_CLIENT_SECRET=
CIDI_REDIRECT_URI=https://incluia.com.ar/auth/cidi/callback

# --- Tests (gov-rls.test.ts) ---
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON=
TEST_SUPABASE_SERVICE_ROLE=
TEST_GOV_EMAIL=
TEST_GOV_PASSWORD=

# --- Evals ---
# EVALS_MODEL=claude-sonnet-4-6
# EVALS_LIMIT=60
# EVALS_CONCURRENCY=3
# EVALS_FILTER_ID=
